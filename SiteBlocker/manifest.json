{
  "manifest_version": 3,
  "name": "Site Blocker",
  "version": "1.4.0",
  "description": "Блокировка сайтов + фильтры рекламы/трекеров (DNR). Whitelist, расписание, JSON.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "declarativeNetRequest", "history", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Site Blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "sb_filters_ads",
        "enabled": false,
        "path": "filters/ads.json"
      }
    ]
  }
}
