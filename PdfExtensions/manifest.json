{
  "manifest_version": 3,
  "name": "Page Capture - tiles 1440x1024",
  "version": "1.0.2",
  "description": "Capture page screenshots as tiles in PNG or PDF. Clear error messages.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": ["http://*/*", "https://*/*", "file://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Page Capture",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
